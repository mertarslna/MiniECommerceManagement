@model List<MiniECommerce.Web.Models.ProductListViewModel>

@{
    ViewData["Title"] = "Ürünler";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Ürün Envanteri</h1>
        <p class="page-subtitle">Mağazanızdaki tüm ürünleri listeleyin, düzenleyin ve takip edin.</p>
    </div>
    <a asp-controller="Product" asp-action="Create" class="btn-premium btn-primary-p text-decoration-none">
        <i class="bi bi-plus-lg"></i> Yeni Ürün Ekle
    </a>
</div>

<div class="glass-card">
    @if (Model == null || Model.Count == 0)
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
            </div>
            <h3 class="fw-bold">Ürün Listesi Boş</h3>
            <p class="text-muted">Görünüşe göre henüz bir ürün eklenmemiş veya veriler çekilemedi.</p>
            <a asp-controller="Product" asp-action="Create" class="btn btn-outline-primary mt-2">
                Hemen Ürün Ekle
            </a>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Ürün Bilgisi</th>
                        <th>Kategori</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge-p bg-secondary bg-opacity-10 text-muted">#@item.Id</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                        <i class="bi bi-box"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold">@item.Name</div>
                                        <div class="text-muted small">SKU-@item.Id.ToString().PadLeft(5, '0')</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge-p bg-info bg-opacity-10 text-info">
                                    <i class="bi bi-tag-fill me-1"></i> @item.CategoryName
                                </span>
                            </td>
                            <td>
                                <span class="badge-p badge-success">Aktif</span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" 
                                       class="btn-premium btn-outline-p btn-sm">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                    </a>
                                    <form asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu ürünü silmek istediğinize emin misiniz?');" style="display:inline;">
                                        <button type="submit" class="btn-premium btn-outline-p btn-sm" title="Sil">
                                            <i class="bi bi-trash3 text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>