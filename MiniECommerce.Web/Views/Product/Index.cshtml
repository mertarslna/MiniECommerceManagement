@model List<MiniECommerce.Entity.Entities.Product>

@{
    ViewData["Title"] = "Ürünler";
}

<h2>Ürünler</h2>

<a class="btn btn-primary mb-3" asp-action="Create">Yeni Ürün Ekle</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Ad</th>
            <th>Kategori</th>
            <th>Fiyat</th>
            <th>Stok</th>
            <th>Durum</th>
            <th>Oluşturulma Tarihi</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Category?.Name</td>
                <td>@product.Price.ToString("C")</td>
                <td>@product.Stock</td>
                <td>@(product.IsActive ? "Aktif" : "Pasif")</td>
                <td>@product.CreatedDate.ToShortDateString()</td>
                <td>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@product.Id">Düzenle</a>
                    @if (product.IsActive)
                    {
                        <a class="btn btn-sm btn-danger" asp-action="Deactivate" asp-route-id="@product.Id">Pasif Yap</a>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-success" asp-action="Activate" asp-route-id="@product.Id">Aktif Yap</a>
                    }
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@product.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>