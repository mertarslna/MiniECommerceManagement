@model MiniECommerce.Web.Models.ProductCreateViewModel

@{
    ViewData["Title"] = "Yeni Ürün";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Yeni Ürün Ekle</h1>
        <p class="page-subtitle">Envanterinize yeni bir ürün tanımlayın.</p>
    </div>
    <a asp-action="Index" class="btn-premium btn-outline-p text-decoration-none">
        <i class="bi bi-arrow-left"></i> Vazgeç
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="glass-card">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="badge-p badge-danger mb-4 d-block text-start p-3"></div>

                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label asp-for="Name" class="form-label">Ürün Adı</label>
                            <input asp-for="Name" class="form-input" placeholder="Örn: iPhone 15 Pro Max" />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="CategoryId" class="form-label">Kategori</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-input">
                                <option value="">Seçiniz...</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-group">
                            <label asp-for="Description" class="form-label">Açıklama</label>
                            <textarea asp-for="Description" class="form-input" rows="3" placeholder="Ürün özellikleri, teknik detaylar..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Price" class="form-label">Birim Fiyat (₺)</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-input" placeholder="0.00" />
                            <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Stock" class="form-label">Stok Adedi</label>
                            <input asp-for="Stock" type="number" class="form-input" placeholder="0" />
                            <span asp-validation-for="Stock" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Görünürlük</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                                <label class="form-check-label text-muted" for="IsActive">Satışa Açık</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-group">
                            <label asp-for="ImageUrl" class="form-label">Görsel URL</label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-link-45deg"></i></span>
                                <input asp-for="ImageUrl" class="form-input" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" placeholder="https://..." />
                            </div>
                            <span asp-validation-for="ImageUrl" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-3 border-top border-secondary border-opacity-20 d-flex gap-3">
                    <button type="submit" class="btn-premium btn-primary-p flex-grow-1 justify-content-center">
                        <i class="bi bi-plus-circle"></i> Ürünü Sisteme Ekle
                    </button>
                    <button type="reset" class="btn-premium btn-outline-p">
                        Sıfırla
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
