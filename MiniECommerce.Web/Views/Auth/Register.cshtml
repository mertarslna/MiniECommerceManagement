@model RegisterViewModel

@{
    ViewData["Title"] = "Yeni Hesap Oluştur";
}

<div class="mb-4">
    <div asp-validation-summary="ModelOnly" class="badge-p badge-danger w-100 text-start p-3 mb-3"></div>
    
    <form asp-action="Register" method="post">
        <div class="form-group mb-3">
            <label asp-for="Name" class="form-label">Ad Soyad</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted px-3">
                    <i class="bi bi-person"></i>
                </span>
                <input asp-for="Name" class="form-input" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" placeholder="Adınız Soyadınız" />
            </div>
            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Email" class="form-label">E-posta Adresi</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted px-3">
                    <i class="bi bi-envelope"></i>
                </span>
                <input asp-for="Email" class="form-input" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" placeholder="isim@sirket.com" />
            </div>
            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="form-group mb-4">
            <label asp-for="Password" class="form-label">Şifre Oluştur</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted px-3">
                    <i class="bi bi-lock"></i>
                </span>
                <input asp-for="Password" type="password" class="form-input" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" placeholder="En az 8 karakter" />
            </div>
            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
        </div>

        <button type="submit" class="btn-premium btn-primary-p w-100 justify-content-center py-3 fs-6">
            Hesabımı Oluştur <i class="bi bi-person-plus ms-2"></i>
        </button>
    </form>
</div>

<div class="text-center mt-3">
    <p class="text-muted small">Zaten bir hesabınız var mı? <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Giriş Yapın</a></p>
</div>