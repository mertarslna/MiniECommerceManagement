@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="fade-in-up">
    <div class="row justify-content-center mt-5">
        <div class="col-lg-5">
            <div class="admin-card text-center">
                <div class="card-body py-5">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4" style="width: 80px; height: 80px; background: rgba(239,68,68,0.1);">
                        <i class="bi bi-exclamation-octagon-fill fs-1" style="color: var(--admin-danger);"></i>
                    </div>
                    <h3 class="fw-bold mb-2">Bir hata oluştu</h3>
                    <p class="text-muted">İsteğiniz işlenirken beklenmeyen bir hata meydana geldi.</p>

                    @if (Model.ShowRequestId)
                    {
                        <div class="alert alert-light border mt-3">
                            <small><strong>Request ID:</strong> <code>@Model.RequestId</code></small>
                        </div>
                    }

                    <a href="/" class="btn btn-admin-primary mt-3">
                        <i class="bi bi-house me-1"></i> Ana Sayfaya Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
