@model List<MiniECommerce.Entity.Entities.Category>
@{
    ViewData["Title"] = "Kategoriler";
}

<h2>Kategoriler</h2>

<a class="btn btn-primary mb-3" asp-action="Create">Yeni Kategori Ekle</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Ad</th>
            <th>Durum</th>
            <th>Oluşturulma Tarihi</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Id</td>
                <td>@category.Name</td>
                <td>@(category.IsActive ? "Aktif" : "Pasif")</td>
                <td>@category.CreatedDate.ToShortDateString()</td>
                <td>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@category.Id">Düzenle</a>
                    @if (category.IsActive)
                    {
                        <a class="btn btn-sm btn-danger" asp-action="Deactivate" asp-route-id="@category.Id">Pasif Yap</a>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-success" asp-action="Activate" asp-route-id="@category.Id">Aktif Yap</a>
                    }
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@category.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>