@model List<MiniECommerce.Web.Models.CategoryListViewModel>

@{
    ViewData["Title"] = "Kategoriler";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Kategori Yönetimi</h1>
        <p class="page-subtitle">Ürünlerinizi gruplandırmak için kategoriler oluşturun ve yönetin.</p>
    </div>
    <a asp-controller="Category" asp-action="Create" class="btn-premium btn-primary-p text-decoration-none">
        <i class="bi bi-plus-lg"></i> Yeni Kategori
    </a>
</div>

<div class="glass-card">
    @if (Model == null || Model.Count == 0)
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-folder-x text-muted" style="font-size: 3rem;"></i>
            </div>
            <h3 class="fw-bold">Hiç Kategori Bulunamadı</h3>
            <p class="text-muted">Henüz hiç kategori eklenmemiş veya API bağlantısında bir sorun var.</p>
            <a asp-controller="Category" asp-action="Create" class="btn btn-outline-primary mt-2">
                İlk Kategoriyi Ekle
            </a>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th style="width: 100px;">ID</th>
                        <th>Kategori Adı</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge-p bg-secondary bg-opacity-10 text-muted">#@item.Id</span>
                            </td>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-controller="Category" asp-action="Edit" asp-route-id="@item.Id" 
                                       class="btn-premium btn-outline-p btn-sm" title="Düzenle">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                    </a>
                                    <form asp-controller="Category" asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');" style="display:inline;">
                                        <button type="submit" class="btn-premium btn-outline-p btn-sm" title="Sil">
                                            <i class="bi bi-trash3 text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>