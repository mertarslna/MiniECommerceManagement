@model List<MiniECommerce.Entity.Entities.Order>
@{
    ViewData["Title"] = "Siparişler";
}

<h2>Siparişler</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Order No</th>
            <th>Müşteri</th>
            <th>Tarih</th>
            <th>Toplam</th>
            <th>Durum</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderNumber</td>
                <td>@order.CustomerName</td>
                <td>@order.OrderDate.ToShortDateString()</td>
                <td>@order.TotalPrice.ToString("C")</td>
                <td>@order.Status</td>
                <td>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@order.Id">Detay</a>
                    <a class="btn btn-sm btn-warning" asp-action="UpdateStatus" asp-route-id="@order.Id">Durum Güncelle</a>
                </td>
            </tr>
        }
    </tbody>
</table>