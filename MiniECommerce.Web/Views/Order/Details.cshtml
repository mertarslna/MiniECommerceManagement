@model MiniECommerce.Entity.Entities.Order
@{
    ViewData["Title"] = "Sipariş Detay";
}

<h2>Sipariş Detayı</h2>

<div class="card mb-4">
    <div class="card-body">
        <p><strong>Sipariş No:</strong> @Model.OrderNumber</p>
        <p><strong>Müşteri:</strong> @Model.CustomerName</p>
        <p><strong>Tarih:</strong> @Model.OrderDate.ToShortDateString()</p>
        <p><strong>Toplam:</strong> @Model.TotalPrice.ToString("C")</p>
        <p><strong>Durum:</strong> <span class="badge bg-info">@Model.Status</span></p>
    </div>
</div>

<h3>Siparişteki Ürünler</h3>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Ürün Görseli</th>
            <th>Ürün Adı</th>
            <th>Adet</th>
            <th>Birim Fiyat</th>
            <th>Ara Toplam</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.OrderItems != null && Model.OrderItems.Any())
        {
            foreach (var item in Model.OrderItems)
            {
                <tr>
                    <td>
                        @* Eğer Product nesnesi de Include edilmişse *@
                        <img src="@item.Product.ImageUrl" width="50" alt="@item.Product.Name" />
                    </td>
                    <td>@item.Product.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("C")</td>
                    <td>@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">Bu siparişe ait ürün bulunamadı.</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>