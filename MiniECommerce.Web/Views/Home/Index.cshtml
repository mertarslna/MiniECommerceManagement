@{
    ViewData["Title"] = "Ana Sayfa - Yönetim Paneli";
}

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    "primary": "#306ee8",
                    "background-light": "#f6f6f8",
                    "background-dark": "#111621",
                },
                fontFamily: {
                    "display": ["Inter"]
                },
                borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
            },
        },
    }
</script>

<div class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 min-h-screen p-8">
    <div class="max-w-6xl mx-auto flex flex-col gap-8">

        <div class="flex flex-col gap-1">
            <h1 class="text-slate-900 dark:text-slate-100 text-3xl font-extrabold tracking-tight">Yönetim Paneli</h1>
            <p class="text-slate-500 dark:text-slate-400 text-base">E-ticaret sisteminizi yönetmek için bir modül seçin.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            <a href="/Product" class="group bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 no-underline flex flex-col gap-4">
                <div class="h-14 w-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                    <span class="material-symbols-outlined text-[28px]">inventory_2</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-primary transition-colors">Ürünler</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Envanterinizi, ürün fiyatlandırmalarını, stok durumunu ve yeni ürün girişlerini buradan yönetin.</p>
                </div>
            </a>

            <a href="/Category" class="group bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 no-underline flex flex-col gap-4">
                <div class="h-14 w-14 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-600 dark:text-emerald-400 group-hover:bg-emerald-500 group-hover:text-white transition-colors duration-300">
                    <span class="material-symbols-outlined text-[28px]">category</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-emerald-500 transition-colors">Kategoriler</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Ürünlerinizi sınıflandırmak için yeni kategoriler oluşturun ve mevcut hiyerarşiyi düzenleyin.</p>
                </div>
            </a>

            <a href="/Order" class="group bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 no-underline flex flex-col gap-4">
                <div class="h-14 w-14 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-600 dark:text-amber-400 group-hover:bg-amber-500 group-hover:text-white transition-colors duration-300">
                    <span class="material-symbols-outlined text-[28px]">local_shipping</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-amber-500 transition-colors">Siparişler</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Müşteri siparişlerini görüntüleyin, kargo durumlarını güncelleyin ve ödemeleri takip edin.</p>
                </div>
            </a>

        </div>
    </div>
</div>